# Lumen environment variables

# Anthropic (required for live eligibility analysis)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_EVAL=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5

# Supabase (server-side only — never expose service role to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Trial portfolio (pinned regression only — discovery mode uses CT.gov search)
LUMEN_TRIAL_NCTS=NCT07070232,NCT06348927,NCT07174388
LUMEN_PINNED_NCTS=

# CT.gov discovery settings
LUMEN_MAX_DISCOVERED_TRIALS=10
LUMEN_CTGOV_STATUS=RECRUITING
LUMEN_CTGOV_PHASES=PHASE2,PHASE3,PHASE4

# Internal: optional entailment re-check (not yet wired)
LUMEN_ENTAILMENT_CHECK=false
