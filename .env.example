# Lumen environment variables

# Anthropic (required for live eligibility analysis)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_EVAL=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5

# Supabase (optional — caches profiles, verdicts, discovery; charts fall back to data/charts/)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pre-loaded trial portfolio (JSON in data/trials/)
LUMEN_TRIAL_NCTS=NCT07070232,NCT06348927,NCT07174388
LUMEN_PINNED_NCTS=
LUMEN_USE_PINNED_TRIALS=0
LUMEN_PREFER_FILE_CHARTS=1

# CT.gov discovery (when LUMEN_USE_PINNED_TRIALS=0)
LUMEN_CTGOV_FETCH_LIMIT=20
LUMEN_MAX_DISCOVERED_TRIALS=10
LUMEN_CTGOV_STATUS=RECRUITING
LUMEN_CTGOV_PHASES=PHASE2,PHASE3,PHASE4

# Citation entailment verification (requires API key)
LUMEN_ENTAILMENT_CHECK=true

# Live Claude inference for pre-screen (default on when ANTHROPIC_API_KEY is set; set 0 for fixture-only)
LUMEN_LIVE_LLM=1

# Disable Supabase profile/discovery/verdict caches for live demos (0 = use caches in production)
LUMEN_DISABLE_CACHE=0
